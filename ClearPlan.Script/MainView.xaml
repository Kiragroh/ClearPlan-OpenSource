                </DataGrid>

            </Grid>


            <Grid Grid.Row="4" Visibility="Visible">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.5*"/>

                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="20" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Background="#00519A">
                        <TextBlock Style="{x:Null}" 
                      Background="#00519A"
                        Foreground="White"
                        FontWeight="SemiBold"
                       Text=" DVH"
                        VerticalAlignment="Center"
                        />
                        <Button Style="{x:Null}"  
                        Content="Reset DVH" 
                        IsDefault="True"
                           HorizontalAlignment="Right" VerticalAlignment="Center"
                        Click="RefreshDVHClicked" Width="100"  />
                    </Grid>

                    <Grid Grid.Row="1">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.5*"/>
                            <ColumnDefinition Width="5*"/>
                        </Grid.ColumnDefinitions>
                        <ScrollViewer Style="{x:Null}" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                            <ListBox Style="{x:Null}"
                                Name="DVHstrucListBox"
                            Grid.Column="0"
                                
                            ItemsSource="{Binding Structures}">
                                <ListBox.ItemTemplate >
                                    <DataTemplate>
                                        <ListBoxItem Margin="5,0,0,0">

                                            <CheckBox Style="{x:Null}" 
                                            Name="DVHstrucCBs"
                        Content="{Binding Id}"
                        Checked="Structure_OnChecked"
                        Unchecked="Structure_OnUnchecked"
                                            
                        />

                                        </ListBoxItem>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </ScrollViewer>
                        <oxy:PlotView
                            Grid.Column="1"
                            Model="{Binding PlotModel}">
                            <oxy:PlotView.ContextMenu>
                                <ContextMenu>
                                    <MenuItem
                                        Header="Export to PDF..."
                                        Click="ExportPlotAsPdf"/>
                                </ContextMenu>
                            </oxy:PlotView.ContextMenu>
                        </oxy:PlotView>
                    </Grid>
                </Grid>

            </Grid>

        </Grid>

    </Grid>

</UserControl>
